<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NewsHub Editorial Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --black: #000000;
            --white: #ffffff;
        }
        * { box-sizing: border-box; }
        body { 
            font-family: 'Open Sans', sans-serif; 
            background-color: var(--white); 
            color: var(--black); 
            margin: 0; 
            padding: 0;
        }
        a { color: var(--black); text-decoration: none; }
        header { 
            background: var(--white);
            border-bottom: 2px solid var(--black);
            padding: 15px 5%; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
        }
        .logo { 
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem; 
            font-weight: 900; 
            text-transform: uppercase;
            letter-spacing: -1px;
            margin: 0;
        }
        .btn-outline { 
            padding: 8px 15px; 
            border: 2px solid var(--black); 
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            transition: all 0.2s ease;
        }
        .btn-outline:hover {
            background: var(--black);
            color: var(--white);
        }
        .container { 
            max-width: 1400px; 
            margin: 40px auto; 
            padding: 40px; 
            background: var(--white); 
            border: 3px solid var(--black);
        }
        h2 {
            font-family: 'Playfair Display', serif;
            margin-top: 0;
            margin-bottom: 30px;
            font-size: 2.5rem;
            border-bottom: 3px solid var(--black);
            padding-bottom: 10px;
        }
        .form-group { margin-bottom: 25px; }
        label { 
            display: block; 
            font-weight: 700; 
            margin-bottom: 8px; 
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }
        input[type="text"], select, textarea, input[type="file"] { 
            width: 100%; 
            padding: 12px; 
            border: 1px solid var(--black); 
            font-family: inherit; 
            font-size: 1rem;
            background: var(--white);
            color: var(--black);
        }
        input[type="text"]:focus, select:focus, textarea:focus {
            outline: none;
            border-width: 2px;
        }
        textarea { height: 200px; resize: vertical; }
        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid var(--black);
            padding: 12px;
        }
        .checkbox-group input { width: auto; transform: scale(1.2); }
        .btn-primary { 
            background-color: var(--black); 
            color: var(--white); 
            border: 2px solid var(--black); 
            padding: 15px 30px; 
            font-size: 1.1rem; 
            font-weight: 700; 
            text-transform: uppercase;
            width: 100%;
            cursor: pointer; 
            transition: all 0.2s ease;
            letter-spacing: 1px;
        }
        .btn-primary:hover { 
            background-color: var(--white); 
            color: var(--black);
        }
    </style>
</head>
<body>
    <header>
        <h1 class="logo">NewsHub Editorial</h1>
        <a href="/" class="btn-outline">Back to Frontpage</a>
    </header>
    
    <div class="container">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
            <!-- Left Side: Publish Form -->
            <div>
                <h2>Submit to Press</h2>
                <form action="/articles" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="title">Headline</label>
                        <input type="text" id="title" name="title" required placeholder="Enter the main headline...">
                    </div>
                    
                    <div class="form-group" style="display: flex; gap: 20px;">
                        <div style="flex: 1;">
                            <label for="category">Category</label>
                            <select id="category" name="category">
                                <option value="Politics">Politics</option>
                                <option value="National">National</option>
                                <option value="World">World</option>
                                <option value="Technology">Technology</option>
                                <option value="Business">Business</option>
                                <option value="Science">Science</option>
                                <option value="Sports">Sports</option>
                            </select>
                        </div>
                        <div style="flex: 1; display: flex; align-items: flex-end;">
                            <div class="checkbox-group" style="width: 100%;">
                                <input type="checkbox" id="is_important" name="is_important">
                                <label for="is_important" style="margin: 0; font-weight: 700; cursor: pointer;">Flag as Front Page / Breaking News</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="content">Editorial Content</label>
                        <textarea id="content" name="content" required placeholder="Write the full article..."></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="image">Cover Photograph (Optional)</label>
                        <input type="file" id="image" name="image" accept="image/*">
                    </div>
                    
                    <button type="submit" class="btn-primary">Publish Article</button>
                </form>
            </div>
            
            <!-- Right Side: Manage Articles -->
            <div>
                <h2>Manage Articles</h2>
                <div style="overflow-y: auto; max-height: 700px; border: 2px solid var(--black);">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead style="background: var(--black); color: var(--white); text-align: left;">
                            <tr>
                                <th style="padding: 15px; border-bottom: 2px solid #000; font-family: 'Open Sans'; text-transform: uppercase;">Title</th>
                                <th style="padding: 15px; border-bottom: 2px solid #000; font-family: 'Open Sans'; text-transform: uppercase;">Category</th>
                                <th style="padding: 15px; border-bottom: 2px solid #000; font-family: 'Open Sans'; text-transform: uppercase; text-align: center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% articles.forEach(article => { %>
                                <tr style="border-bottom: 1px solid var(--black);">
                                    <td style="padding: 15px; font-weight: 600; font-family: 'Playfair Display', serif; font-size: 1.1rem;">
                                        <%= article.title.length > 40 ? article.title.substring(0, 40) + '...' : article.title %>
                                        <% if(article.is_important) { %><br><span style="font-size: 0.7rem; color: #d32f2f; font-family: 'Open Sans'; text-transform: uppercase; font-weight: bold;">Breaking</span><% } %>
                                    </td>
                                    <td style="padding: 15px; font-size: 0.9rem; text-transform: uppercase;"><%= article.category %></td>
                                    <td style="padding: 15px; text-align: center;">
                                        <form action="/articles/<%= article.id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Are you sure you want to completely delete this article from the database?');">
                                            <button type="submit" style="background: #cc0000; color: white; border: 2px solid #000; padding: 8px 12px; cursor: pointer; font-weight: bold; text-transform: uppercase; font-size: 0.8rem; box-shadow: 3px 3px 0 #000;">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if(articles.length === 0) { %>
                                <tr><td colspan="3" style="padding: 20px; text-align: center; font-style: italic;">No articles published yet.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
